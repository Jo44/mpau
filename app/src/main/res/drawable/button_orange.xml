<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <corners android:radius="3dip" />
            <stroke android:width="1dip" android:color="@color/black" />
            <gradient android:angle="-90" android:endColor="@color/darkorange" android:startColor="@color/darkerorange" />
        </shape>
    </item>
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <corners android:radius="3dip" />
            <stroke android:width="1dip" android:color="@color/black" />
            <solid android:color="@color/darkorange" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="3dip" />
            <stroke android:width="1dip" android:color="@color/black" />
            <gradient android:angle="-90" android:endColor="@color/lightorange" android:startColor="@color/orange" />
        </shape>
    </item>
</selector>