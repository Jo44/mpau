<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="10dp">

    <TextView
        android:id="@+id/typeInter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:textColor="@color/orange"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/subtypeInter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignBaseline="@id/typeInter"
        android:layout_toEndOf="@id/typeInter"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/smurInter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignBaseline="@id/typeInter"
        android:layout_marginEnd="20dp"
        android:layout_toEndOf="@id/subtypeInter"
        android:textSize="12sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/secteurInter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/typeInter"
        android:layout_marginEnd="25dp"
        android:layout_marginStart="25dp"
        android:textSize="12sp"
        android:textStyle="italic" />

    <TextView
        android:id="@+id/commentInter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/secteurInter"
        android:layout_marginEnd="25dp"
        android:layout_marginStart="25dp"
        android:textSize="12sp"
        android:textStyle="italic" />

    <TextView
        android:id="@+id/datetimeInter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/commentInter"
        android:layout_marginEnd="25dp"
        android:layout_marginStart="25dp"
        android:textSize="12sp"
        android:textStyle="italic" />

    <View
        android:id="@+id/lineOverInterBloc"
        android:layout_width="100dp"
        android:layout_height="1dp"
        android:layout_below="@id/datetimeInter"
        android:layout_centerHorizontal="true"
        android:background="@color/lightgrey" />

</RelativeLayout>